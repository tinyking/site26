---
import MainLayout from '@/layouts/MainLayout.astro';
import JournalDetailPage from '@/components/gallery/JournalDetailPage';
import { getCollection, getEntry } from 'astro:content';

const { slug } = Astro.params;
const entry = await getEntry('journal', slug!);
const post = entry?.data;

export async function getStaticPaths() {
  const entries = await getCollection('journal');
  
  return entries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}
---

<MainLayout title="Journal - Jianchao Wang">
  <JournalDetailPage post={post} content={await entry?.render()} client:load />
</MainLayout>
