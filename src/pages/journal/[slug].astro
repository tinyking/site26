---
import MainLayout from '@/layouts/MainLayout.astro';
import JournalDetailPage from '@/components/gallery/JournalDetailPage';

const { slug } = Astro.params;

export function getStaticPaths() {
  const slugs = [
    'golden-hour-photography',
    'day-in-the-life',
    'everyday-moments',
    'minimalist-composition',
  ];
  
  return slugs.map((slug) => ({
    params: { slug },
  }));
}
---

<MainLayout title="Journal - Jianchao Wang">
  <JournalDetailPage slug={slug} client:load />
</MainLayout>
